services:
  synapse:
    image: matrixdotorg/synapse:latest
    container_name: synapse
    restart: always
    environment:
      - SYNAPSE_SERVER_NAME=${DOMAIN}
      - SYNAPSE_REPORT_STATS='no'
    volumes:
      - ../data:/data
      - ../logs:/var/log/synapse
    networks:
      - ${SHARED_NETWORK}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8008/health"]
      interval: 30s
      timeout: 10s
      retries: 3

networks:
  ${SHARED_NETWORK}:
    external: true