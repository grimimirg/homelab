services:
  n8n:
    image: n8nio/n8n:latest
    container_name: n8n
    user: ${HOST_UID}:${HOST_GID}
    restart: always
    environment:
      - N8N_HOST=0.0.0.0
      - N8N_PORT=5678
      - N8N_USER_FOLDER=/data
    ports:
        - "5678:5678"
    volumes:
      - ../data/n8n:/data
    networks:
      - ${SHARED_NETWORK}

networks:
  ${SHARED_NETWORK}:
    external: true