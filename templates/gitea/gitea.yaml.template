services:
  gitea:
    image: gitea/gitea:latest
    container_name: gitea
    # user: ${HOST_UID}:${HOST_GID}
    restart: always
    environment:
      - GITEA__server__SSH_PORT=2222
      - GITEA__server__DOMAIN=git.${DOMAIN}
      - GITEA__server__ROOT_URL=https://git.${DOMAIN}
    ports:
      - "2222:22"
    volumes:
      - ../data/gitea:/data
    networks:
      - ${SHARED_NETWORK}

networks:
  ${SHARED_NETWORK}:
    external: true