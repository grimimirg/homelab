services:
  nginx:
    image: nginx:alpine
    container_name: nginx
    # user: ${HOST_UID}:${HOST_GID}
    restart: always
    ports:
      - "80:80"
      - "443:443"
      - "8448:8448"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./conf.d:/etc/nginx/conf.d:ro
      - ../ssl:/etc/letsencrypt/live/${DOMAIN}:ro
    networks:
      - ${SHARED_NETWORK}

networks:
  ${SHARED_NETWORK}:
    external: true
