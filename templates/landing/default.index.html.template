<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homelab</title>
    <link rel="stylesheet" href="/homelab-theme.css">
</head>
<body>
<div class="container">
    <header>
        <button onclick="logout()" class="logout-btn">LOGOUT</button>
        <h1>Homelab Services</h1>
        <p>${DOMAIN}</p>
    </header>

    <div class="services-grid">
        <a href="http://git.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">🦊</div>
            <div class="service-name">Gitea</div>
            <div class="service-description">Git repository hosting</div>
            <div class="service-url">git.${DOMAIN}</div>
        </a>

        <a href="http://n8n.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">🔗</div>
            <div class="service-name">n8n</div>
            <div class="service-description">Workflow automation</div>
            <div class="service-url">n8n.${DOMAIN}</div>
        </a>

        <a href="http://music.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">🎵</div>
            <div class="service-name">Navidrome</div>
            <div class="service-description">Music streaming server</div>
            <div class="service-url">music.${DOMAIN}</div>
        </a>

        <a href="http://docs.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">📄</div>
            <div class="service-name">Paperless</div>
            <div class="service-description">Document management</div>
            <div class="service-url">docs.${DOMAIN}</div>
        </a>

        <a href="http://synapse.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">💬</div>
            <div class="service-name">Synapse</div>
            <div class="service-description">Matrix server</div>
            <div class="service-url">synapse.${DOMAIN}</div>
        </a>
    </div>
</div>

<script>
function logout() {
    fetch('https://auth.${DOMAIN}/api/logout', {
        method: 'POST',
        credentials: 'include',
        headers: {
            'Content-Type': 'application/json'
        }
    })
    .then(response => {
        window.location.href = 'https://auth.${DOMAIN}';
    })
    .catch(error => {
        console.error('Logout error:', error);
        window.location.href = 'https://auth.${DOMAIN}';
    });
}
</script>
</body>
</html>
