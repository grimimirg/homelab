<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homelab</title>
    <link rel="stylesheet" href="/homelab-theme.css">
    <script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>
</head>
<body>
<div class="container">
    <header>
        <button onclick="logout()" class="logout-btn">LOGOUT</button>
        <h1>Homelab Services</h1>
        <p>${DOMAIN}</p>
    </header>

    <div class="services-grid">
        <a href="http://git.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">🦊</div>
            <div class="service-name">Gitea</div>
            <div class="service-description">Git repository hosting</div>
            <div class="service-url">git.${DOMAIN}</div>
        </a>

        <a href="http://n8n.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">🔗</div>
            <div class="service-name">n8n</div>
            <div class="service-description">Workflow automation</div>
            <div class="service-url">n8n.${DOMAIN}</div>
        </a>

        <a href="http://music.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">🎵</div>
            <div class="service-name">Navidrome</div>
            <div class="service-description">Music streaming server</div>
            <div class="service-url">music.${DOMAIN}</div>
        </a>

        <a href="http://docs.${DOMAIN}" target="_blank" class="service-card">
            <div class="service-icon">📄</div>
            <div class="service-name">Paperless</div>
            <div class="service-description">Document management</div>
            <div class="service-url">docs.${DOMAIN}</div>
        </a>
    </div>

    <div class="stats-section">
        <h2 class="section-title">Server Performance</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">🖥️</div>
                <div class="stat-value" id="cpu-percent">--</div>
                <div class="stat-label">CPU Usage</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🧠</div>
                <div class="stat-value" id="memory-percent">--</div>
                <div class="stat-label">Memory</div>
                <div class="stat-detail" id="memory-detail">-- / -- GB</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">💿</div>
                <div class="stat-value" id="disk-percent">--</div>
                <div class="stat-label">Disk Usage</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📡</div>
                <div class="stat-value" id="network-traffic">--</div>
                <div class="stat-label">Network</div>
                <div class="stat-detail" id="network-detail">↑ -- / ↓ --</div>
            </div>
        </div>
    </div>

    <div class="stats-section">
        <h2 class="section-title">Docker Status</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">📦</div>
                <div class="stat-value" id="containers-running">--</div>
                <div class="stat-label">Running</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">⏸️</div>
                <div class="stat-value" id="containers-stopped">--</div>
                <div class="stat-label">Stopped</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">💾</div>
                <div class="stat-value" id="total-images">--</div>
                <div class="stat-label">Images</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🌐</div>
                <div class="stat-value" id="total-networks">--</div>
                <div class="stat-label">Networks</div>
            </div>
        </div>
        <div class="container-list">
            <h3 class="subsection-title">Active Containers</h3>
            <div id="container-details" class="container-details">
                <div class="loading">[ LOADING... ]</div>
            </div>
        </div>
    </div>

    <p style="margin-top: 15px; opacity: 0.5;">Template created by Claudione</p>
</div>

<script>
    function logout() {
        fetch('https://auth.${DOMAIN}/api/logout', {
            method: 'POST',
            credentials: 'include',
            headers: {
                'Content-Type': 'application/json'
            }
        })
            .then(response => {
                window.location.href = 'https://auth.${DOMAIN}';
            })
            .catch(error => {
                console.error('Logout error:', error);
                window.location.href = 'https://auth.${DOMAIN}';
            });
    }

    function controlContainer(containerId, action) {
        fetch(`/api/docker/container/$${{containerId}}/$${{action}}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log(data.message);
                    fetchDockerStats();
                } else {
                    console.error('Error:', data.error);
                    alert('Error: ' + data.error);
                }
            })
            .catch(error => {
                console.error('Error controlling container:', error);
                alert('Error controlling container: ' + error);
            });
    }

    function formatBytes(bytes) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }

    function updateServerPerformances(data) {
        document.getElementById('cpu-percent').textContent = data.cpuPercent.toFixed(1) + '%';
        document.getElementById('memory-percent').textContent = data.memoryPercent.toFixed(1) + '%';
        document.getElementById('memory-detail').textContent = 
            `$${{data.memory.used}} / $${{data.memory.total}} GB`;
        document.getElementById('disk-percent').textContent = data.diskPercent.toFixed(1) + '%';
        
        const totalTraffic = data.network.bytesSent + data.network.bytesRecv;
        document.getElementById('network-traffic').textContent = formatBytes(totalTraffic);
        document.getElementById('network-detail').textContent = 
            `↑ $${{formatBytes(data.network.bytesSent)}} / ↓ $${{formatBytes(data.network.bytesRecv)}}`;
    }

    function initPerformanceWebSocket() {
        const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
        const socket = io(`$${{protocol}}//$${{window.location.host}}/performance`, {
            transports: ['websocket', 'polling']
        });

        socket.on('connect', () => {
            console.log('Connected to performance stream');
        });

        // the method server_performance is defined in the app.py file
        socket.on('server_performance', (data) => {
            updateServerPerformances(data);
        });

        socket.on('disconnect', () => {
            console.log('Disconnected from performance stream');
        });

        socket.on('connect_error', (error) => {
            console.error('WebSocket connection error:', error);
        });
    }

    function fetchDockerStats() {
        fetch('/api/docker/stats')
            .then(response => response.json())
            .then(data => {
                document.getElementById('containers-running').textContent = data.running || 0;
                document.getElementById('containers-stopped').textContent = data.stopped || 0;
                document.getElementById('total-images').textContent = data.images || 0;
                document.getElementById('total-networks').textContent = data.networks || 0;

                const containerDetails = document.getElementById('container-details');
                if (data.containers && data.containers.length > 0) {
                    containerDetails.innerHTML = data.containers.map(container => `
                    <div class="container-item">
                        <div class="container-status $${{container.state.toLowerCase()}}"></div>
                        <div class="container-info">
                            <div class="container-name">$${{container.name}}</div>
                            <div class="container-meta">
                                <span class="container-image">$${{container.image}}</span>
                                <span class="container-uptime">$${{container.uptime || 'N/A'}}</span>
                            </div>
                        </div>
                        <div class="container-actions">
                            <button onclick="controlContainer('$${{container.id}}', 'start')" class="action-btn start-btn" title="Start">▶</button>
                            <button onclick="controlContainer('$${{container.id}}', 'stop')" class="action-btn stop-btn" title="Stop">■</button>
                            <button onclick="controlContainer('$${{container.id}}', 'restart')" class="action-btn restart-btn" title="Restart">↻</button>
                        </div>
                    </div>
                `).join('');
                } else {
                    containerDetails.innerHTML = '<div class="no-data">[ NO CONTAINERS FOUND ]</div>';
                }
            })
            .catch(error => {
                console.error('Error fetching Docker stats:', error);
                document.getElementById('container-details').innerHTML = '<div class="error">[ ERROR LOADING DATA ]</div>';
            });
    }

    // Initialize WebSocket for real-time performance updates
    initPerformanceWebSocket();
    
    // Fetch Docker stats on load and refresh every 10 seconds
    fetchDockerStats();
    setInterval(fetchDockerStats, 10000);
</script>
</body>
</html>
